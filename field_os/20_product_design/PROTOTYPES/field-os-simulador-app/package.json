{
  "name": "field-os-simulador-app",
  "version": "1.0.0",
  "private": true,
  "description": "Prototipo auditado del simulador de sustratos de Setas de la Peña",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "node scripts/quality-check.mjs",
